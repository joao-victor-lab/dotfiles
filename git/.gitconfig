[user]
  name = joao-victor-lab
  email = 79527341+joao-victor-lab@users.noreply.github.com 
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFcpPwlIqhO77qrhCPJTI0L/fYew2aBtSygmxJpiQqDm joaosan17017vic@gmail.com


[tag]
	gpdsing = true

[commit]
	gpdsing = true

[push]
	autoSetupRemote = true

[init]
  defaultBranch = main

[core]
  editor = nvim
  pager = delta 

[interactive]
   diffFilter = delta --color-only --features=interactive

[delta]
  features = decorations

[delta "interactive"]
  keep-plus-minus-markers = false

[delta "decorations"]
  commit-decoration-style = blue ol
  commit-style = raw
  file-style = omit
  hunk-header-decoration-style = blue box
  hunk-header-file-style = red
  hunk-header-line-number-style = "#067a00"
  hunk-header-style = file line-number syntax

[alias]
	c = commit -s
	s = status
	l = log
	all = add .


[gpg]
	format = ssh
